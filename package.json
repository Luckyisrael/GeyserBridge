{
  "name": "geyser-bridge",
  "version": "1.0.0",
  "description": "Yellowstone Geyser gRPC-compatible server backed by free Solana RPC WebSockets",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "solana",
    "geyser",
    "grpc",
    "yellowstone",
    "streaming"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/node": "^25.9.3",
    "@types/pino": "^7.0.4",
    "tsx": "^4.22.4",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}
