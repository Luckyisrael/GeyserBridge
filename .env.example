# gRPC server
PORT=10000
HOST=0.0.0.0

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# TLS (leave empty for insecure dev)
TLS_CERT_PATH=
TLS_KEY_PATH=

# Admin key for creating API keys
ADMIN_KEY=change-me-to-a-random-secret

# Logging
LOG_LEVEL=info

# Performance
MAX_STREAMS_PER_CONNECTION=100
MAX_CONNECTIONS=10
PING_INTERVAL_MS=15000
PING_TIMEOUT_MS=60000
SLOT_BUFFER_SIZE=500
GRPC_MAX_MESSAGE_LENGTH=67108864
